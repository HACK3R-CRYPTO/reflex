import { PublicClient, WalletClient, Address, Abi, TransactionReceipt, Hex } from 'viem';

type Client = {
    public: PublicClient;
    wallet?: WalletClient;
};

declare class Viem {
    client: Client;
    private chainId;
    constructor(client: Client);
    getChainId(): Promise<number>;
    readContract<T>(address: Address, abi: Abi, functionName: string, args?: unknown[]): Promise<T>;
    writeContract(address: Address, abi: Abi, functionName: string, args?: unknown[], value?: bigint): Promise<`0x${string}` | null>;
    waitForTransaction(hash: `0x${string}`): Promise<TransactionReceipt>;
    getCurrentAccounts(): Promise<Address[]>;
}

type EthCall = {
    from?: Address;
    to: Address;
    gas?: Hex;
    gasPrice?: Hex;
    value?: Hex;
    data?: Hex;
};
/**
 * @property ethCalls Fixed set of ETH calls that must be executed before onData callback is triggered. Multicall3 is recommended. Can be an empty array
 * @property context Event sourced selectors to be added to the data field of ETH calls, possible values: topic0, topic1, topic2, topic3, topic4, data and address
 * @property onData Callback for a successful reactivity notification
 * @property onError Callback for a failed attempt
 * @property eventContractSources Alternative contract event source(s) (any on somnia) that will be emitting the logs specified by topicOverrides
 * @property topicOverrides Optional filter for specifying topics of interest, otherwise wildcard filter is applied (all events watched)
 * @property onlyPushChanges Whether the data should be pushed to the subscriber only if eth_call results are different from the previous
 */
type WebsocketSubscriptionInitParams = {
    ethCalls: EthCall[];
    context?: string;
    onData: (data: any) => void;
    onError?: (error: Error) => void;
    eventContractSources?: Address[];
    topicOverrides?: Hex[];
    onlyPushChanges?: boolean;
};
type SuccessResult<result> = {
    method?: undefined;
    result: result;
    error?: undefined;
};
type ErrorResult<error> = {
    method?: undefined;
    result?: undefined;
    error: error;
};
type Subscription<result, error> = {
    method: 'eth_subscription';
    error?: undefined;
    result?: undefined;
    params: {
        subscription: string;
        result: result;
        error?: undefined;
    } | {
        subscription: string;
        result?: undefined;
        error: error;
    };
};
type RpcResponse<result = any, error = any> = {
    jsonrpc: `${number}`;
    id: number;
} & (SuccessResult<result> | ErrorResult<error> | Subscription<result, error>);
type WebSocketTransportSubscribeReturnType = {
    subscriptionId: Hex;
    unsubscribe: () => Promise<RpcResponse<boolean>>;
};
/**
 * @property The notification result data containing information about the event topic, data and view results
 */
type SubscriptionCallback = {
    result: {
        topics: Hex[];
        data: Hex;
        simulationResults: Hex[];
    };
};
/**
 * @property eventTopics Optional event filters
 * @property origin Optional tx.origin filter
 * @property caller Optional msg.sender filter
 * @property emitter Optional contract event emitter filter
 * @property handlerContractAddress Contract that will handle subscription callback
 * @property handlerFunctionSelector Optional override for specifying callback handler function
 * @property priorityFeePerGas Additional priority fee that will be paid per gas consumed by callback
 * @property maxFeePerGas Maximum fee per gas the subscriber is willing to pay (base fee + priority fee)
 * @property gasLimit Maximum gas that will be provisioned per subscription callback
 * @property isGuaranteed Whether event notification must be delivered regardless of block inclusion distance from emission
 * @property isCoalesced Whether multiple events can be coalesced into a single handling call per block
 */
type SoliditySubscriptionData = {
    eventTopics?: Hex[];
    origin?: Address;
    caller?: Address;
    emitter?: Address;
    handlerContractAddress: Address;
    handlerFunctionSelector?: Hex;
    priorityFeePerGas: bigint;
    maxFeePerGas: bigint;
    gasLimit: bigint;
    isGuaranteed: boolean;
    isCoalesced: boolean;
};
type BlockTickSubscription = {
    blockNumber?: bigint;
} & Omit<SoliditySubscriptionData, 'eventTopics' | 'origin' | 'caller' | 'emitter'>;
type ScheduleRequest = {
    timestampMs: number;
} & Omit<SoliditySubscriptionData, 'eventTopics' | 'origin' | 'caller' | 'emitter'>;
type SoliditySubscriptionInfo = {
    subscriptionData: SoliditySubscriptionData;
    owner: Address;
};

declare class Reactivity {
    viem: Viem;
    constructor(client: Client);
    /**
     * Typescript event subscriptions to Solidity events which bundle any ETH call result along with event log data
     * @param param0 See SubscriptionInitParams type which defines the events being observed, the eth calls executed and callback fn to call
     * @returns The node subscription identifier and an unsubscribe callback or an Error object if the subscription fails to start
     */
    subscribe({ ethCalls, context, onData, onError, eventContractSources, topicOverrides, onlyPushChanges }: WebsocketSubscriptionInitParams): Promise<WebSocketTransportSubscribeReturnType | Error>;
    /**
     * Start a subscription to events emitted by smart contracts with the callback being handled by a Solidity smart contract
     * @param subscription Defines the parameters for the subscription, mapping to wild card defaults where optional arguments are not provided
     * @returns A transaction hash if successful or a JS Error object containing failure reason
     */
    createSoliditySubscription(subscription: SoliditySubscriptionData): Promise<Hex | Error>;
    /**
     * Cancels an active contract event subscription being handled by a solidity smart contract
     * @param subscriptionId The unique identifier for the subscription issued on subscription creation
     * @returns A transaction hash if successful or a JS Error object containing failure reason
     */
    cancelSoliditySubscription(subscriptionId: bigint): Promise<Hex | Error>;
    /**
     * Create a subscription to the head of the chain reaching a specific (or any) block number
     * @param param0 The block subscription definition optionally including the block number
     * @returns Transaction hash if subscription was created or Error if a subscription was not created
     */
    createOnchainBlockTickSubscription({ blockNumber, handlerContractAddress, handlerFunctionSelector, priorityFeePerGas, maxFeePerGas, gasLimit, isGuaranteed, isCoalesced }: BlockTickSubscription): Promise<Hex | Error>;
    /**
     * Schedule a smart contract callback in the future
     * @param param0 Subscription definition including the timestamp in ms
     * @returns Transaction hash if the cron was successfully scheduled or Error if a subscription was not created
     */
    scheduleOnchainCronJob({ timestampMs, handlerContractAddress, handlerFunctionSelector, priorityFeePerGas, maxFeePerGas, gasLimit, isGuaranteed, isCoalesced }: ScheduleRequest): Promise<Hex | Error>;
    /**
     * Gets the detailed parameters of a Solidity subscription given a unique subscription identifer
     * @param subscriptionId Subscription identifier
     * @returns The populated subscription or JS Error if the query failed
     */
    getSubscriptionInfo(subscriptionId: bigint): Promise<SoliditySubscriptionInfo | Error>;
}

declare class SDK extends Reactivity {
    /**
     * Create a new SDK instance
     * @param client Viem wrapper object for consuming the public client and optionally the wallet client for transactions
     */
    constructor(client: Client);
}

export { type EthCall, Reactivity, SDK, type SoliditySubscriptionData, type SoliditySubscriptionInfo, type SubscriptionCallback, type WebsocketSubscriptionInitParams };
